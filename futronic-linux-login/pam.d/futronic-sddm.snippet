# Insertar antes de la primera linea auth requerida/incluida en /etc/pam.d/sddm.
# El instalador scripts/install-cachy.sh lo hace automaticamente con marcadores.
auth sufficient pam_exec.so quiet /usr/local/bin/futronic-auth verify --pam-user

# Insertar al final de /etc/pam.d/sddm para abrir KDE Wallet cuando PAM
# recibe la contrasena normal del usuario.
-auth optional pam_kwallet5.so
-session optional pam_kwallet5.so auto_start
